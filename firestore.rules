rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth Data Helper (Safer version)
    function peekUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'thenajmulhuda@gmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && peekUserData().role == 'superadmin')
      );
    }
    
    function isPrincipal(collegeId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && peekUserData().role == 'principal' && peekUserData().collegeId == collegeId;
    }
    
    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && peekUserData().role == 'teacher';
    }

    function isTeacherAt(collegeId) {
      return isTeacher() && peekUserData().collegeId == collegeId;
    }

    function isCollegeMember(collegeId) {
       return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && peekUserData().collegeId == collegeId;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Health Check ---
    match /test/connection {
      allow read: if true;
    }

    // --- College Rules ---
    match /colleges/{collegeId} {
      function isValidCollege(data) {
        return data.name is string && data.name.size() > 0 &&
               data.createdAt is timestamp;
      }
      allow read: if isSignedIn();
      allow create: if isSuperAdmin() && isValidCollege(incoming());
      allow update: if (isSuperAdmin() || isPrincipal(collegeId)) && isValidCollege(incoming());
      allow delete: if isSuperAdmin();
    }

    // --- User Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.email is string && data.email.size() > 0 &&
               data.role in ['superadmin', 'principal', 'teacher', 'student'];
      }

      allow get: if isSignedIn() && (isOwner(userId) || isSuperAdmin() || existing().email == request.auth.token.email || (isPrincipal(peekUserData().collegeId) && existing().collegeId == peekUserData().collegeId));
      allow list: if isSuperAdmin() || (isSignedIn() && (resource.data.email == request.auth.token.email || (resource.data.collegeId != null && isPrincipal(resource.data.collegeId)) || isTeacher()));
      
      allow create: if (isSignedIn() && (isOwner(userId) || isSuperAdmin() || isPrincipal(incoming().collegeId) || isTeacherAt(incoming().collegeId))) && 
                       isValidUser(incoming()) && incoming().createdAt is timestamp;
      
      allow update: if isSignedIn() && (isOwner(userId) || isSuperAdmin() || (isPrincipal(peekUserData().collegeId) || isTeacherAt(peekUserData().collegeId)) && existing().collegeId == peekUserData().collegeId) && (
        isSuperAdmin() || 
        ((isPrincipal(peekUserData().collegeId) || isTeacherAt(peekUserData().collegeId)) && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'classId', 'status', 'officialName', 'displayName', 'rollNo', 'trade', 'email', 'updatedAt', 'collegeId', 'imageUrl'])) ||
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'trade', 'rollNo', 'imageUrl']) && incoming().role == existing().role)
      );

      allow delete: if isSuperAdmin() || (isSignedIn() && (existing().email == request.auth.token.email || isPrincipal(existing().collegeId) || isTeacherAt(existing().collegeId)));
    }

    // --- Question Rules ---
    match /questions/{questionId} {
      function isValidQuestion(data) {
        return data.text is string && data.text.size() > 0 &&
               data.options is map &&
               data.answer is string &&
               data.createdBy is string &&
               data.createdAt is timestamp;
      }

      allow read: if isSignedIn();
      allow create: if (isSuperAdmin() || isPrincipal(incoming().collegeId) || isTeacherAt(incoming().collegeId)) && isValidQuestion(incoming());
      allow update: if (isSuperAdmin() || (isSignedIn() && (isPrincipal(existing().collegeId) || (isTeacherAt(existing().collegeId) && existing().createdBy == request.auth.uid)))) && isValidQuestion(incoming());
      allow delete: if isSuperAdmin() || (isSignedIn() && (isPrincipal(existing().collegeId) || (isTeacherAt(existing().collegeId) && existing().createdBy == request.auth.uid)));
    }

    // --- Question Share Rules ---
    match /question_shares/{shareId} {
      function isValidQuestionShare(data) {
        return data.sourceCollegeId is string &&
               data.sourceCollegeId.size() > 0 &&
               data.targetCollegeId is string &&
               data.targetCollegeId.size() > 0 &&
               data.scopeType in ['subject', 'chapter'] &&
               data.subject is string &&
               data.subject.size() > 0 &&
               data.createdBy is string &&
               data.createdAt is timestamp &&
               (
                 data.scopeType == 'subject' ||
                 (data.chapter is string && data.chapter.size() > 0)
               );
      }

      allow read: if isSuperAdmin() || (isSignedIn() && (isCollegeMember(existing().targetCollegeId) || isCollegeMember(existing().sourceCollegeId)));
      allow create: if isSuperAdmin() && isValidQuestionShare(incoming());
      allow update: if isSuperAdmin() && isValidQuestionShare(incoming());
      allow delete: if isSuperAdmin();
    }

    // --- Test Rules ---
    match /tests/{testId} {
      function isValidTest(data) {
        return data.title is string && data.title.size() > 0 &&
               data.teacherId is string &&
               data.questionIds is list &&
               data.createdAt is timestamp;
      }

      allow read: if isSignedIn();
      allow create: if (isSuperAdmin() || isPrincipal(incoming().collegeId) || isTeacherAt(incoming().collegeId)) && isValidTest(incoming()) && (isSuperAdmin() || incoming().teacherId == request.auth.uid || isPrincipal(incoming().collegeId));
      allow update: if (isSuperAdmin() || isPrincipal(existing().collegeId) || (isTeacherAt(existing().collegeId) && existing().teacherId == request.auth.uid)) && isValidTest(incoming());
      allow delete: if isSuperAdmin() || isPrincipal(existing().collegeId) || (isTeacherAt(existing().collegeId) && existing().teacherId == request.auth.uid);
    }

    // --- Submission Rules ---
    match /submissions/{subId} {
      function isValidSubmission(data) {
        return data.testId is string &&
               data.answers is map &&
               data.score is int &&
               data.submittedAt is timestamp;
      }

      allow get: if isSignedIn() && (isOwner(existing().studentId) || isSuperAdmin() || isPrincipal(existing().collegeId) || isTeacherAt(existing().collegeId));
      allow list: if isSuperAdmin() || (isSignedIn() && (isPrincipal(resource.data.collegeId) || isTeacherAt(resource.data.collegeId) || resource.data.studentId == request.auth.uid));
      
      allow create: if isSignedIn() && isValidSubmission(incoming()) && (incoming().studentId == request.auth.uid || incoming().studentId == 'anonymous');
      
      allow update: if (isSuperAdmin() || isPrincipal(existing().collegeId) || isTeacherAt(existing().collegeId)) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['released']);
      
      allow delete: if isSuperAdmin();
    }

    // --- Class Rules ---
    match /classes/{classId} {
      function isValidClass(data) {
        return data.name is string && data.name.size() > 0 &&
               data.teacherId is string &&
               data.collegeId is string &&
               data.createdAt is timestamp;
      }
      allow read: if isSignedIn();
      allow create: if (isPrincipal(incoming().collegeId) || isSuperAdmin()) && isValidClass(incoming());
      allow update: if (isPrincipal(existing().collegeId) || isSuperAdmin()) && isValidClass(incoming());
      allow delete: if (isPrincipal(existing().collegeId) || isSuperAdmin());
    }

    // --- Attendance Rules ---
    // Collection used by Teacher/Principal/SuperAdmin dashboards to store daily attendance.
    match /attendance/{attendanceId} {
      function isValidAttendance(data) {
        return data.collegeId is string &&
               data.collegeId.size() > 0 &&
               data.date is string &&
               data.date.size() > 0 &&
               data.studentId is string &&
               data.studentId.size() > 0 &&
               data.status in ['present', 'absent', 'late'] &&
               data.updatedAt is timestamp;
      }

      // Important: attendance must not hard-fail for legacy teacher/principal accounts
      // that have not finished UID profile migration. Enforce only signed-in access here
      // and validate the attendance payload itself.
      allow read: if isSignedIn();

      allow create, update: if isSignedIn() && isValidAttendance(incoming());

      allow delete: if isSuperAdmin() || (existing().collegeId is string && isPrincipal(existing().collegeId));
    }

    // --- Practice Progress Rules ---
    // Used by Practice tests to autosave answers/review flags for a student.
    match /practice_progress/{progressId} {
      function isOwnerProgressId() {
        return isSignedIn() && progressId.matches('^' + request.auth.uid + '_');
      }

      function isValidPracticeProgress(data) {
        return data.studentId is string &&
               data.studentId.size() > 0 &&
               data.testId is string &&
               data.testId.size() > 0 &&
               data.answers is map &&
               data.reviewIds is list &&
               data.currentIdx is int &&
               data.lastUpdated is timestamp;
      }

      // Allow reading your own progress doc even if it doesn't exist yet (so getDoc returns empty instead of PERMISSION_DENIED).
      allow read: if isSuperAdmin() || isOwnerProgressId();

      allow create, update: if isSignedIn() && (
        isSuperAdmin() ||
        (isOwnerProgressId() && incoming().studentId == request.auth.uid && isValidPracticeProgress(incoming()))
      );

      allow delete: if isSuperAdmin() || existing().studentId == request.auth.uid;
    }
  }
}
